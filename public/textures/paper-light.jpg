</div>    <script>
      function toggleMenu(element) {
        const isOpen = element.classList.contains('open');
        const menuItems = document.querySelectorAll('.custom-dropdown .menu > li');

        // Close all menus except the clicked one
        menuItems.forEach((item) => {
          if (item !== element) {
            item.classList.remove('open');
          }
        });

        // Toggle the clicked menu
        if (!isOpen) {
          element.classList.add('open');
          saveOpenMenu(element.getAttribute('data-menu'));
        } else {
          element.classList.remove('open');
          localStorage.removeItem('openMenu'); // Remove saved state if closed
        }
      }

      function saveOpenMenu(menu) {
        localStorage.setItem('openMenu', menu);
      }

      function loadOpenMenu() {
        const openMenu = localStorage.getItem('openMenu');
        if (openMenu) {
          const menuItem = document.querySelector(`.custom-dropdown .menu > li[data-menu="${openMenu}"]`);
          if (menuItem) {
            menuItem.classList.add('open', 'no-transition'); // Add "no-transition" class on load
          }
        }
      }

      // Disable transitions for the initial load
      window.addEventListener('load', () => {
        loadOpenMenu();

        // Remove the "no-transition" class after the load
        setTimeout(() => {
          const openMenuItem = document.querySelector('.custom-dropdown .menu > li.open.no-transition');
          if (openMenuItem) {
            openMenuItem.classList.remove('no-transition');
          }
        }, 50); // Slight delay to ensure it loads without animation
      });

      // Save the open main category when a subcategory is clicked
      document.querySelectorAll('.custom-dropdown .submenu li a').forEach((submenuLink) => {
        submenuLink.addEventListener('click', (event) => {
          event.stopPropagation(); // Prevent the main menu from closing
          const openMenu = submenuLink.closest('li.open');
          if (openMenu) {
            saveOpenMenu(openMenu.getAttribute('data-menu'));
          }
        });
      });
    </script>
        <script>
        function moveVatField() {
            var vatField = document.getElementById("edd-card-vat-wrap");
            var zipField = document.getElementById("edd-card-zip-wrap");

            if (vatField && zipField && zipField.parentNode) {
                zipField.parentNode.insertBefore(vatField, zipField.nextSibling);
            }
        }

        // Wait for Billing Address to load
        var observer = new MutationObserver(function(mutations, observer) {
            if (document.getElementById("edd-card-zip-wrap")) {
                moveVatField();
                observer.disconnect(); // Stop observing after moving
            }
        });

        observer.observe(document.body, { childList: true, subtree: true });
    </script>
