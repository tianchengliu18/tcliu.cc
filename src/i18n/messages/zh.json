    "story2": "\u6211\u7684\u7814\u7a76\u4e4b\u8def\u59cb\u4e8e\u4e00\u4e2a\u622a\u7136\u4e0d\u540c\u7684\u8d77\u70b9\u2014\u2014\u672c\u79d1\u5728\u534e\u5357\u7406\u5de5\u5927\u5b66\u5b66\u4e60\u7f51\u7edc\u5de5\u7a0b\u548c\u91d1\u878d\u5b66\uff0c\u7136\u540e\u5728\u65e9\u7a3b\u7530\u5927\u5b66\u5ea6\u8fc7\u4e86\u4e24\u5e74\uff0c\u7814\u7a76\u533a\u5757\u94fe\u4e0e\u4e91\u8ba1\u7b97\u3002\u5728\u4e2d\u56fd\u7535\u4fe1\u7814\u7a76\u9662\u505a\u5de5\u7a0b\u5e08\u540e\uff0c\u6211\u610f\u8bc6\u5230\u81ea\u5df1\u771f\u6b63\u7684\u70ed\u60c5\u5728\u4e8e\u6280\u672f\u4e0e\u6587\u5316\u7684\u4ea4\u6c47\u5904\u3002",
    "story3": "\u73b0\u5728\u6211\u7684\u7814\u7a76\u65b9\u5411\u662f\u4e2d\u56fd\u4e66\u6cd5\u7684\u8ba1\u7b97\u89e3\u8bfb\u3001\u4eba\u673a\u5171\u521b\u7cfb\u7edf\u4ee5\u53ca\u690d\u6839\u6587\u5316\u7684\u751f\u6210\u5f0f AI\u3002\u6211\u7740\u8ff7\u4e8e\u673a\u5668\u5982\u4f55\u5728\u5c0a\u91cd\u6587\u5316\u9057\u4ea7\u7684\u540c\u65f6\uff0c\u7406\u89e3\u5e76\u53c2\u4e0e\u827a\u672f\u521b\u4f5c\u3002",
